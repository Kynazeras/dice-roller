; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="dice_roller"
run/main_scene="uid://gckk7oleb6uk"
config/features=PackedStringArray("4.5", "Mobile")
run/max_fps=240
config/icon="res://icon.svg"

[autoload]

DiceRollManager="*res://autoloads/dice_roll_manager.gd"
GameConfigManager="*res://autoloads/game_config.gd"
GameManager="*res://autoloads/game_manager.gd"
SaveManager="*res://autoloads/save_manager.gd"
SceneManager="*res://autoloads/scene_manager.gd"

[display]

window/size/viewport_width=480
window/size/viewport_height=854
window/stretch/mode="canvas_items"
window/stretch/aspect="expand"
window/handheld/orientation=1

[gui]

theme/custom="uid://vgf0xnhfl12x"

[input_devices]

pointing/emulate_touch_from_mouse=true

[rendering]

renderer/rendering_method="mobile"
anti_aliasing/quality/msaa_2d=1
environment/defaults/default_clear_color=Color(0.4509804, 0.27450982, 0.29803923, 1)
